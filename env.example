# Copy these into Vercel → Project → Settings → Environment Variables
# (Do NOT put real secrets in this file or commit them to GitHub.)

# ---------- Mailing list (holding page “Notify me”) ----------
MAILCHIMP_API_KEY=paste-your-mailchimp-api-key-here
MAILCHIMP_AUDIENCE_ID=paste-your-audience-id-here

# Optional — usually taken from the end of the API key (e.g. us1)
# MAILCHIMP_SERVER_PREFIX=us1

# "true" = double opt-in (recommended for UK). "false" = subscribe immediately.
MAILCHIMP_DOUBLE_OPT_IN=true

# ---------- Contact form (full shop page → emails you) ----------
# Create a free key at https://resend.com/api-keys
RESEND_API_KEY=re_paste-your-resend-api-key-here

# Where contact messages are delivered
CONTACT_TO_EMAIL=admindudes@luckisfordudes.com

# Sender address (must be allowed by Resend).
# While testing / before domain verify, use Resend’s onboarding sender:
CONTACT_FROM_EMAIL=Luck Is For Dudes <onboarding@resend.com>
# After you verify luckisfordudes.com in Resend, switch to something like:
# CONTACT_FROM_EMAIL=Luck Is For Dudes <hello@luckisfordudes.com>
